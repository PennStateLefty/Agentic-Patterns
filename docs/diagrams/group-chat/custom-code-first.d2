...@../shared/theme.d2

direction: right

associate: Associate {
  class: actor
}

gateway: API Management (Platform-adjacent) {
  class: adjacent
}

runtime: Application-Selected Runtime {
  class: adjacent

  api: Agent API {
    class: custom
  }

  manager: Agent Framework Group Chat Manager {
    class: native
  }

  participants: Agent Framework Participants {
    class: native
  }

  synthesizer: Final Synthesizer {
    class: native
  }
}

custom: Application-Owned Chat Policy {
  style: {
    fill: "#FFFBEB"
    stroke: "#C19C00"
    stroke-width: 2
    border-radius: 10
  }

  policy: Speaker, Conflict, Completion, and Limits {
    class: custom
  }

  compaction: Context Selection and Compaction {
    class: custom
  }

  reliability: Idempotent Turns and Side Effects {
    class: custom
  }
}

adjacent: Azure Execution and State (Platform-adjacent) {
  style: {
    fill: "#F5FFF7"
    stroke: "#107C10"
    stroke-width: 2
    border-radius: 10
  }

  shared_chat: Cosmos DB / SQL Shared Chat {
    class: adjacent
    shape: cylinder
  }

  checkpoint: Cosmos DB / SQL Round Checkpoints {
    class: adjacent
    shape: cylinder
  }

  decisions: Cosmos DB / SQL Decisions {
    class: adjacent
    shape: cylinder
  }

  artifacts: Blob Storage Artifacts {
    class: adjacent
    shape: cylinder
  }

  approval: HITL API / Teams Escalation {
    class: adjacent
  }

  tools: Functions / MCP Services {
    class: adjacent
  }

  telemetry: Application Insights / OpenTelemetry {
    class: adjacent
  }
}

associate -> gateway: accommodation request
gateway -> runtime.api: authenticated request
runtime.api -> runtime.manager
custom.policy -> runtime.manager: speaker + stop rules
custom.compaction -> runtime.manager: bounded shared context
adjacent.shared_chat -> runtime.manager: current discussion
runtime.manager -> runtime.participants: select next speaker
custom.reliability -> runtime.participants: idempotent turn
runtime.participants -> adjacent.tools: tools
runtime.participants -> adjacent.shared_chat: append contribution
runtime.participants -> adjacent.decisions: structured finding
runtime.manager -> adjacent.checkpoint: round boundary
runtime.manager -> runtime.synthesizer: completion reached
adjacent.shared_chat -> runtime.synthesizer: completed discussion
runtime.synthesizer -> adjacent.artifacts: recommendation
runtime.manager -> adjacent.approval: unresolved / high risk
runtime.api -> adjacent.telemetry: rounds + speakers + cost
runtime.api -> gateway: recommendation + escalation
gateway -> associate: recommendation + escalation
