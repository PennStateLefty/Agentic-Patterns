...@../shared/theme.d2

direction: right

associate: Associate {
  class: actor
}

gateway: API Management (Platform-adjacent) {
  class: adjacent
}

runtime: Application-Selected Runtime {
  class: adjacent

  api: Case / Agent API {
    class: custom
  }

  listener: Agent Framework Event / Work Listener {
    class: native
  }

  workers: Agent Framework Specialist Contributors {
    class: native
  }
}

custom: Application-Owned Workspace Policy {
  style: {
    fill: "#FFFBEB"
    stroke: "#C19C00"
    stroke-width: 2
    border-radius: 10
  }

  claims: Claim, Lease, and Optimistic-Concurrency Logic {
    class: custom
  }

  completion: Conflict, Stale-Work, and Completion Policy {
    class: custom
  }

  reliability: Idempotency, Inbox / Outbox, and Compensation {
    class: custom
  }
}

adjacent: Azure Shared Workspace (Platform-adjacent) {
  style: {
    fill: "#F5FFF7"
    stroke: "#107C10"
    stroke-width: 2
    border-radius: 10
  }

  blackboard: Cosmos DB / SQL Shared Working State {
    class: adjacent
    shape: cylinder
  }

  ledger: Cosmos DB / SQL Tasks and Claims {
    class: adjacent
    shape: cylinder
  }

  artifacts: Blob Storage Versioned Artifacts {
    class: adjacent
    shape: cylinder
  }

  commands: Service Bus Work Commands {
    class: adjacent
  }

  events: Event Grid / Change Feed Events {
    class: adjacent
  }

  approval: HITL API / Teams Callback {
    class: adjacent
  }

  tools: Functions / MCP Services {
    class: adjacent
  }

  telemetry: Application Insights / OpenTelemetry {
    class: adjacent
  }
}

associate -> gateway: create workplace case
gateway -> runtime.api: authenticated request
runtime.api -> adjacent.blackboard: structured request
adjacent.blackboard -> adjacent.events: state change
adjacent.events -> runtime.listener: work available
runtime.listener -> custom.claims: claim request
custom.claims -> adjacent.ledger: conditional claim / lease
runtime.listener -> adjacent.commands: owned work command
adjacent.commands -> runtime.workers: at-least-once delivery
custom.reliability -> runtime.workers: idempotent contribution
adjacent.blackboard -> runtime.workers: current facts
adjacent.artifacts -> runtime.workers: pinned evidence
runtime.workers -> adjacent.tools: tool calls
runtime.workers -> adjacent.blackboard: optimistic update
runtime.workers -> adjacent.artifacts: new artifact version
runtime.workers -> adjacent.ledger: result + release claim
custom.completion -> adjacent.ledger: stale-work + terminal rules
adjacent.approval -> adjacent.blackboard: human decision
runtime.api -> adjacent.telemetry: contribution correlation
runtime.api -> gateway: status / outcome
gateway -> associate: status / outcome
