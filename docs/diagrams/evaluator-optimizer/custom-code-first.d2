...@../shared/theme.d2

direction: right

associate: Associate {
  class: actor
}

gateway: API Management (Platform-adjacent) {
  class: adjacent
}

runtime: Application-Selected Runtime {
  class: adjacent

  api: Agent API {
    class: custom
  }

  controller: Agent Framework Revision Graph {
    class: native
  }

  generator: Drafting Optimizer {
    class: native
  }

  evaluator: Policy Evaluator {
    class: native
  }
}

custom: Application-Owned Quality Policy {
  style: {
    fill: "#FFFBEB"
    stroke: "#C19C00"
    stroke-width: 2
    border-radius: 10
  }

  rubric: Versioned Rubric and Thresholds {
    class: custom
  }

  completion: Approval, Iteration, and Cost Limits {
    class: custom
  }

  reliability: Idempotency and Artifact Pinning {
    class: custom
  }
}

adjacent: Azure Execution and State (Platform-adjacent) {
  style: {
    fill: "#F5FFF7"
    stroke: "#107C10"
    stroke-width: 2
    border-radius: 10
  }

  candidate: Cosmos DB / SQL Candidate and Feedback {
    class: adjacent
    shape: cylinder
  }

  checkpoint: Cosmos DB / SQL Checkpoints {
    class: adjacent
    shape: cylinder
  }

  artifacts: Blob Storage Versioned Artifacts {
    class: adjacent
    shape: cylinder
  }

  approval: HITL API / Teams Callback {
    class: adjacent
  }

  tools: Functions / MCP Services {
    class: adjacent
  }

  telemetry: Application Insights / OpenTelemetry {
    class: adjacent
  }
}

associate -> gateway: exception-request goal
gateway -> runtime.api: authenticated request
runtime.api -> runtime.controller
runtime.controller -> runtime.generator: create / revise
runtime.generator -> adjacent.tools: evidence tools
runtime.generator -> adjacent.candidate: candidate version
adjacent.candidate -> runtime.evaluator: exact version
custom.rubric -> runtime.evaluator: criteria + thresholds
runtime.evaluator -> adjacent.candidate: score + feedback
adjacent.candidate -> runtime.controller: evaluation result
custom.completion -> runtime.controller: pass + hard limits
runtime.controller -> runtime.generator: revision required
runtime.controller -> adjacent.checkpoint: iteration boundary
custom.reliability -> runtime.controller: retry + version policy
runtime.controller -> adjacent.artifacts: approved version
runtime.controller -> adjacent.approval: high-risk / missing evidence
runtime.api -> adjacent.telemetry: iterations + scores + cost
runtime.api -> gateway: approved result / escalation
gateway -> associate: result
