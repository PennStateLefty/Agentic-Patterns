...@../shared/theme.d2

direction: right

associate: Associate {
  class: actor
}

gateway: API Management (Platform-adjacent) {
  class: adjacent
}

runtime: Application-Selected Runtime {
  class: adjacent

  api: Agent API {
    class: custom
  }

  supervisor: Agent Framework Supervisor Composition {
    class: native
  }

  workers: Agents as Tools / Specialist Workers {
    class: native
  }

  synthesis: Result Aggregator and Synthesizer {
    class: native
  }
}

custom: Application-Owned Supervision Policy {
  style: {
    fill: "#FFFBEB"
    stroke: "#C19C00"
    stroke-width: 2
    border-radius: 10
  }

  registry: Worker Registry and Tenant Rules {
    class: custom
  }

  contracts: Delegation, Conflict, and Stop Policy {
    class: custom
  }

  reliability: Idempotency and Compensation {
    class: custom
  }
}

adjacent: Azure Execution and State (Platform-adjacent) {
  style: {
    fill: "#F5FFF7"
    stroke: "#107C10"
    stroke-width: 2
    border-radius: 10
  }

  ledger: Cosmos DB / SQL Delegation Ledger {
    class: adjacent
    shape: cylinder
  }

  checkpoint: Cosmos DB / SQL Checkpoints {
    class: adjacent
    shape: cylinder
  }

  durable: Durable Task Scheduler {
    class: adjacent
  }

  queue: Service Bus Commands {
    class: adjacent
  }

  artifacts: Blob Storage Artifacts {
    class: adjacent
    shape: cylinder
  }

  approval: HITL API / Teams Callback {
    class: adjacent
  }

  tools: Functions / MCP Services {
    class: adjacent
  }

  telemetry: Application Insights / OpenTelemetry {
    class: adjacent
  }
}

associate -> gateway: cross-domain goal
gateway -> runtime.api: authenticated request
runtime.api -> runtime.supervisor: retained session
custom.registry -> runtime.supervisor: worker capabilities
custom.contracts -> runtime.supervisor: bounded delegation rules
runtime.supervisor -> adjacent.queue: worker command
adjacent.queue -> runtime.workers: bounded assignment
runtime.workers -> adjacent.tools: tool calls
custom.reliability -> runtime.workers: side-effect policy
runtime.workers -> runtime.synthesis: bounded result
runtime.supervisor -> adjacent.ledger: assignment + outcome
runtime.synthesis -> runtime.supervisor: reconciled evidence
runtime.supervisor -> adjacent.checkpoint: standard checkpoint
adjacent.durable -> runtime.supervisor: conditional resume
runtime.supervisor -> adjacent.artifacts: sequenced plan
runtime.supervisor -> adjacent.approval: exception
runtime.api -> adjacent.telemetry: delegation traces + cost
runtime.api -> gateway: unified response
gateway -> associate: unified response
