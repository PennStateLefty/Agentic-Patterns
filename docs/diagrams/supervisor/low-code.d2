...@../shared/theme.d2

direction: right

associate: Associate {
  class: actor
}

cps: Copilot Studio (Native) {
  style: {
    fill: "#F7FBFF"
    stroke: "#0078D4"
    stroke-width: 2
    border-radius: 10
  }

  supervisor: Parent Assistance Agent {
    class: native
  }

  session: Parent Conversation Context {
    class: native
    shape: cylinder
  }

  registry: Capability Descriptions {
    class: native
    shape: cylinder
  }

  workers: Child / Connected Specialist Agents {
    class: native
  }
}

custom: Application-Owned Supervision Policy {
  style: {
    fill: "#FFFBEB"
    stroke: "#C19C00"
    stroke-width: 2
    border-radius: 10
  }

  contracts: Delegation and Result Contracts {
    class: custom
  }

  synthesis: Conflict, Completion, and Limit Policy {
    class: custom
  }
}

adjacent: Power Platform (Platform-adjacent) {
  style: {
    fill: "#F5FFF7"
    stroke: "#107C10"
    stroke-width: 2
    border-radius: 10
  }

  ledger: Dataverse Delegation Ledger {
    class: adjacent
    shape: cylinder
  }

  artifacts: SharePoint Artifacts {
    class: adjacent
    shape: cylinder
  }

  flows: Agent Flows / Power Automate {
    class: adjacent
  }

  approval: Human Approval / Escalation {
    class: adjacent
  }

  telemetry: Analytics / Application Insights {
    class: adjacent
  }
}

associate -> cps.supervisor: cross-domain goal
cps.session -> cps.supervisor: retained conversation
cps.registry -> cps.supervisor: worker capabilities
custom.contracts -> cps.supervisor: bounded assignment schema
cps.supervisor -> cps.workers: delegate bounded task
cps.workers -> cps.supervisor: bounded result
cps.supervisor -> adjacent.ledger: assignment + outcome
custom.synthesis -> cps.supervisor: reconcile + stop rules
cps.workers -> adjacent.flows: deterministic actions
cps.supervisor -> adjacent.artifacts: sequenced plan
cps.supervisor -> adjacent.approval: exception
cps.supervisor -> adjacent.telemetry: delegation traces
cps.supervisor -> associate: unified response
