...@../shared/theme.d2

direction: right

associate: Associate {
  class: actor
}

gateway: API Management (Platform-adjacent) {
  class: adjacent
}

runtime: Application-Selected Runtime {
  class: adjacent

  api: Agent API / Channel Adapter {
    class: custom
  }

  transfer: Agent Framework Handoff Orchestration {
    class: native
  }

  it: IT Peer Agent {
    class: native
  }

  security: Identity Security Peer Agent {
    class: native
  }
}

custom: Application-Owned Transfer Policy {
  style: {
    fill: "#FFFBEB"
    stroke: "#C19C00"
    stroke-width: 2
    border-radius: 10
  }

  registry: Peer Registry and Authorization Rules {
    class: custom
  }

  limits: Context Minimization, Hop, and Loop Policy {
    class: custom
  }

  reliability: Idempotent Transfer and Compensation {
    class: custom
  }
}

adjacent: Azure Execution and State (Platform-adjacent) {
  style: {
    fill: "#F5FFF7"
    stroke: "#107C10"
    stroke-width: 2
    border-radius: 10
  }

  owner: Cosmos DB / SQL Current Owner and Audit {
    class: adjacent
    shape: cylinder
  }

  checkpoint: Cosmos DB / SQL Checkpoints {
    class: adjacent
    shape: cylinder
  }

  callbacks: HITL API / Teams Takeover {
    class: adjacent
  }

  tools: Functions / MCP Services {
    class: adjacent
  }

  telemetry: Application Insights / OpenTelemetry {
    class: adjacent
  }
}

associate -> gateway: report access issue
gateway -> runtime.api: authenticated message
runtime.api -> runtime.it: current-owner delivery
runtime.it -> runtime.transfer: request security takeover
custom.registry -> runtime.transfer: eligible peer
custom.limits -> runtime.transfer: context + hop rules
custom.reliability -> runtime.transfer: idempotent transfer
runtime.transfer -> adjacent.owner: compare-and-set active owner
runtime.transfer -> runtime.security: transfer context + control
runtime.security -> adjacent.tools: remediation tools
runtime.security -> runtime.transfer: return after remediation
runtime.transfer -> adjacent.owner: compare-and-set active owner
runtime.transfer -> runtime.it: resume ownership
runtime.transfer -> adjacent.checkpoint: transfer boundary
runtime.transfer -> adjacent.callbacks: conditional human takeover
runtime.api -> adjacent.telemetry: transfer traces
runtime.api -> gateway: active-owner response
gateway -> associate: active-owner response
