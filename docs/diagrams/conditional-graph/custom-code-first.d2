...@../shared/theme.d2

direction: right

associate: Associate {
  class: actor
}

gateway: API Management (Platform-adjacent) {
  class: adjacent
}

runtime: Application-Selected Runtime {
  class: adjacent

  api: Process / Agent API {
    class: custom
  }

  controller: Agent Framework Graph / State Machine {
    class: native
  }

  agents: Review Agents and Executors {
    class: native
  }

  checkpoints: Agent Framework Standard Checkpoints {
    class: native
  }
}

custom: Application-Owned Process Model {
  style: {
    fill: "#FFFBEB"
    stroke: "#C19C00"
    stroke-width: 2
    border-radius: 10
  }

  transitions: Versioned States, Guards, and Terminal Policy {
    class: custom
  }

  reliability: Idempotency, Inbox / Outbox, and Compensation {
    class: custom
  }
}

adjacent: Azure Execution and State (Platform-adjacent) {
  style: {
    fill: "#F5FFF7"
    stroke: "#107C10"
    stroke-width: 2
    border-radius: 10
  }

  checkpoint_store: Cosmos DB / SQL Checkpoint Store {
    class: adjacent
    shape: cylinder
  }

  case_state: Cosmos DB / SQL Business Case {
    class: adjacent
    shape: cylinder
  }

  durable: Durable Task Scheduler {
    class: adjacent
  }

  durable_extension: Agent Framework Durable Extension (Preview) {
    class: preview
  }

  events: Service Bus Commands / Event Grid Events {
    class: adjacent
  }

  approvals: HITL API / Teams Callback {
    class: adjacent
  }

  artifacts: Blob Storage Evidence {
    class: adjacent
    shape: cylinder
  }

  telemetry: Application Insights / OpenTelemetry {
    class: adjacent
  }
}

associate -> gateway: equipment request
gateway -> runtime.api: authenticated request / event
runtime.api -> runtime.controller
custom.transitions -> runtime.controller: states + guarded transitions
runtime.controller -> runtime.agents: bounded state action
runtime.controller -> runtime.checkpoints: checkpoint boundary
runtime.checkpoints -> adjacent.checkpoint_store: persist snapshot
runtime.controller -> adjacent.case_state: business status + decision
runtime.controller -> adjacent.events: command / state-change event
adjacent.durable -> runtime.controller: durable resume / timer
adjacent.durable_extension -> adjacent.durable: optional preview integration
runtime.controller -> adjacent.approvals: suspend for decision
adjacent.approvals -> adjacent.events: authenticated callback
custom.reliability -> runtime.agents: side-effect policy
runtime.agents -> adjacent.artifacts: evidence + output
runtime.api -> adjacent.telemetry: transitions + correlation
runtime.api -> gateway: status / outcome
gateway -> associate: status / outcome
